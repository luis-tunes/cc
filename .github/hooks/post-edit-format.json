{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/session-context.sh",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/safety-rails.sh",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/post-edit-format.sh",
        "timeout": 10
      }
    ]
  }
}
