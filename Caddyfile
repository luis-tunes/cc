# TIM reverse proxy
# ─────────────────────────────────────────────────────────
# Bare IP:  set DOMAIN=:443 in .env (default — self-signed cert)
# Real domain: set DOMAIN=tim.pt  in .env (auto Let's Encrypt)
#   and remove "tls internal" below so Caddy provisions a real cert.

{$DOMAIN::443} {
	tls internal

	# API + webhook → FastAPI backend
	handle /api/* {
		reverse_proxy app:8080
	}
	handle /webhook {
		reverse_proxy app:8080
	}
	handle /health {
		reverse_proxy app:8080
	}

	# Everything else → SPA (served by FastAPI)
	handle {
		reverse_proxy app:8080
	}
}

# Redirect HTTP → HTTPS
http:// {
	redir https://{host}{uri} permanent
}
