#!/bin/bash
# Create the paperless database if it doesn't exist.
# Mounted into postgres as /docker-entrypoint-initdb.d/init-db.sh (needs .sh in container)
set -e
psql -v ON_ERROR_STOP=1 --username "$POSTGRES_USER" --dbname "$POSTGRES_DB" <<-EOSQL
    SELECT 'CREATE DATABASE paperless OWNER $POSTGRES_USER'
    WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = 'paperless')\gexec
EOSQL
