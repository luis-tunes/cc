#!/bin/bash
set -e
cd "$(dirname "$0")/.."

# backend — AUTH_DISABLED=1 + mock DB means no PG needed
AUTH_DISABLED=1 DATABASE_URL="postgresql://cc:cc@localhost:5432/cc" \
  python3 -m pytest app/tests/ -v \
  --cov=app --cov-report=term-missing --cov-fail-under=70 \
  "$@"

# frontend
cd frontend && npm run build
npm test
