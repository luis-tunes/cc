#!/bin/bash
# Pre-commit hook: lint + type-check + build + test.
# Install: make hooks
set -e
ROOT="$(git rev-parse --show-toplevel)"

echo "pre-commit: lint"
ruff check "$ROOT/app/"

echo "pre-commit: type-check"
python3 -m mypy "$ROOT/app/" --ignore-missing-imports

echo "pre-commit: frontend build"
(cd "$ROOT/frontend" && npx vite build --logLevel error)

echo "pre-commit: frontend tests"
(cd "$ROOT/frontend" && npx vitest run --reporter=dot)

echo "pre-commit: ok"
