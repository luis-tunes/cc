#!/bin/bash
# bin/backup — PostgreSQL + Paperless backup
#
# Usage:
#   bin/backup                     # backup to ./backups/
#   bin/backup /path/to/dir        # backup to custom directory
#   BACKUP_RETAIN_DAYS=30 bin/backup  # keep backups for 30 days (default: 7)
#
# Outputs:
#   <dir>/xtim-<timestamp>.sql.gz  — compressed pg_dump
#   <dir>/xtim-<timestamp>.tar.gz  — Paperless media export (if running)
#
set -euo pipefail
cd "$(dirname "$0")/.."

BACKUP_DIR="${1:-./backups}"
RETAIN_DAYS="${BACKUP_RETAIN_DAYS:-7}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
DB_CONTAINER=$(docker compose ps -q db 2>/dev/null || true)

mkdir -p "$BACKUP_DIR"

# ── PostgreSQL dump ───────────────────────────────────────────────────
if [ -n "$DB_CONTAINER" ]; then
  echo "→ Backing up PostgreSQL…"
  docker compose exec -T db pg_dump \
    -U "${POSTGRES_USER:-cc}" \
    --format=custom \
    "${POSTGRES_DB:-cc}" \
    | gzip > "$BACKUP_DIR/xtim-$TIMESTAMP.sql.gz"
  echo "  ✓ $BACKUP_DIR/xtim-$TIMESTAMP.sql.gz"
else
  echo "⚠ PostgreSQL container not running, skipping DB backup"
fi

# ── Paperless media export ────────────────────────────────────────────
PL_CONTAINER=$(docker compose ps -q paperless 2>/dev/null || true)
if [ -n "$PL_CONTAINER" ]; then
  echo "→ Backing up Paperless media…"
  docker compose exec -T paperless \
    document_exporter /tmp/export --no-progress-bar 2>/dev/null || true
  docker compose cp paperless:/tmp/export - \
    | gzip > "$BACKUP_DIR/xtim-paperless-$TIMESTAMP.tar.gz" 2>/dev/null || true
  if [ -f "$BACKUP_DIR/xtim-paperless-$TIMESTAMP.tar.gz" ]; then
    echo "  ✓ $BACKUP_DIR/xtim-paperless-$TIMESTAMP.tar.gz"
  else
    echo "  ⚠ Paperless export failed (non-critical)"
  fi
else
  echo "⚠ Paperless container not running, skipping media backup"
fi

# ── Prune old backups ────────────────────────────────────────────────
echo "→ Pruning backups older than $RETAIN_DAYS days…"
find "$BACKUP_DIR" -name "xtim-*.gz" -mtime "+$RETAIN_DAYS" -delete 2>/dev/null || true

echo "✓ Backup complete"
