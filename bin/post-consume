#!/usr/bin/env bash
set -euo pipefail

echo "post-consume: document_id=${DOCUMENT_ID}" >&2

BODY=$(mktemp)
trap 'rm -f "$BODY"' EXIT

HTTP_CODE=$(curl -s -o "$BODY" -w "%{http_code}" \
  -X POST "http://app:8080/webhook" \
  -H "Content-Type: application/json" \
  -d "{\"document_id\": ${DOCUMENT_ID}}")

cat "$BODY" >&2
echo "" >&2

if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
  echo "post-consume: success (HTTP $HTTP_CODE)" >&2
else
  echo "post-consume: FAILED (HTTP $HTTP_CODE)" >&2
  exit 1
fi
