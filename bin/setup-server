#!/usr/bin/env bash
#
# Bootstrap a fresh server. Run once:
#   ssh root@IP 'bash -s' < bin/setup-server
#
set -euo pipefail

DIR="/opt/cc"
APP_USER="cc"

log() { echo "-- $1"; }

# System
export DEBIAN_FRONTEND=noninteractive
log "a atualizar sistema..."
apt-get update -qq && apt-get upgrade -y -qq

# Swap (2GB — needed for Paperless OCR)
if [ ! -f /swapfile ]; then
  log "a criar 2GB swap..."
  fallocate -l 2G /swapfile && chmod 600 /swapfile
  mkswap /swapfile >/dev/null && swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi

# Docker
if ! command -v docker &>/dev/null; then
  log "a instalar docker..."
  curl -fsSL https://get.docker.com | sh
fi

# Firewall
log "firewall..."
apt-get install -y -qq ufw
ufw allow 22/tcp  >/dev/null 2>&1 || true
ufw allow 80/tcp  >/dev/null 2>&1 || true
ufw allow 443/tcp >/dev/null 2>&1 || true
ufw --force enable >/dev/null 2>&1 || true

# App user
if ! id "$APP_USER" &>/dev/null; then
  log "a criar user $APP_USER..."
  adduser --disabled-password --gecos "" "$APP_USER"
fi
usermod -aG docker "$APP_USER" 2>/dev/null || true

# Directory structure (deploy pushes files here later)
mkdir -p "$DIR/bin"
chown -R "$APP_USER:$APP_USER" "$DIR"

# Generate .env with random passwords
if [ ! -f "$DIR/.env" ]; then
  log "a gerar .env..."
  PG_PASS=$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)
  PL_SECRET=$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)
  PL_ADMIN_PASS=$(openssl rand -base64 16 | tr -d '/+=' | head -c 16)
  cat > "$DIR/.env" << EOF
POSTGRES_DB=cc
POSTGRES_USER=cc
POSTGRES_PASSWORD=${PG_PASS}
PAPERLESS_SECRET_KEY=${PL_SECRET}
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=${PL_ADMIN_PASS}
PAPERLESS_TOKEN=
AUTH_DISABLED=0
DOMAIN=:80
EOF
  chown "$APP_USER:$APP_USER" "$DIR/.env"
  chmod 600 "$DIR/.env"
fi

# SSH key for CI deploy
if [ ! -f "/home/$APP_USER/.ssh/deploy" ]; then
  log "a gerar chave SSH para CI..."
  sudo -u "$APP_USER" mkdir -p "/home/$APP_USER/.ssh"
  sudo -u "$APP_USER" ssh-keygen -t ed25519 -f "/home/$APP_USER/.ssh/deploy" -N "" -q
  cat "/home/$APP_USER/.ssh/deploy.pub" >> "/home/$APP_USER/.ssh/authorized_keys"
  chmod 600 "/home/$APP_USER/.ssh/authorized_keys"
  chown "$APP_USER:$APP_USER" "/home/$APP_USER/.ssh/authorized_keys"
fi

IP=$(curl -sf https://api.ipify.org || hostname -I | awk '{print $1}')
PL_PASS=$(grep PAPERLESS_ADMIN_PASSWORD "$DIR/.env" | cut -d= -f2)

echo ""
echo "--------------------------------------"
echo "  Servidor pronto"
echo "--------------------------------------"
echo ""
echo "  Proximo passo — da maquina local:"
echo "    make deploy HOST=$APP_USER@$IP"
echo ""
echo "  Depois de arrancar, gerar token paperless:"
echo "    ssh $APP_USER@$IP"
echo "    cd $DIR && docker compose exec paperless python3 manage.py shell -c \\"
echo "      \"from rest_framework.authtoken.models import Token; from django.contrib.auth.models import User; t,_=Token.objects.get_or_create(user=User.objects.get(username='admin')); print(t.key)\""
echo "    # colar o token em $DIR/.env como PAPERLESS_TOKEN=..."
echo "    docker compose restart app"
echo ""
echo "  Paperless admin: admin / $PL_PASS"
echo ""
echo "  Para CI automatico (GitHub Secrets):"
echo "  DEPLOY_HOST = $APP_USER@$IP"
echo "  DEPLOY_KEY  ="
cat "/home/$APP_USER/.ssh/deploy" 2>/dev/null || true
echo ""
echo "--------------------------------------"
