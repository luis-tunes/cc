#!/bin/bash
set -e

HOST="${1:?usage: bin/deploy <user@host>}"
DIR="/opt/cc"

bin/test

ssh "$HOST" "command -v docker >/dev/null || curl -fsSL https://get.docker.com | sh"
ssh "$HOST" "mkdir -p $DIR"
rsync -az --delete --exclude '.git' --exclude '__pycache__' --exclude '.env' --exclude 'node_modules' --exclude 'frontend/dist' --exclude 'web' . "$HOST:$DIR/"
ssh "$HOST" "cd $DIR && docker compose up -d --build"
echo "deployed: http://$HOST:8080"
