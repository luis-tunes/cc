#!/bin/bash
set -e

HOST="${1:?usage: bin/deploy <user@host>}"

bin/test

# Server needs docker-compose.yml, .env, and bin/ (for post-consume)
ssh "$HOST" "command -v docker >/dev/null || curl -fsSL https://get.docker.com | sh"
ssh "$HOST" "mkdir -p /opt/cc/bin"
scp docker-compose.yml Caddyfile "$HOST:/opt/cc/"
scp bin/post-consume "$HOST:/opt/cc/bin/"
ssh "$HOST" "cd /opt/cc && docker compose pull app && docker compose up -d"
echo "deployed: http://$HOST"
