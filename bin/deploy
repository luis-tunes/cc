#!/bin/bash
# Deploy to production. Called by CI or manually.
# Usage: bin/deploy user@host   OR   DEPLOY_HOST=user@host bin/deploy
set -euo pipefail
cd "$(dirname "$0")/.."

HOST="${DEPLOY_HOST:-${1:-}}"
[ -z "$HOST" ] && { echo "usage: bin/deploy <user@host> or set DEPLOY_HOST" >&2; exit 1; }

DIR="/home/cc/cc"
SSH="ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10"
SCP="scp -o StrictHostKeyChecking=no"

# SSH key from env (CI) or fall back to agent (manual)
if [ -n "${DEPLOY_KEY:-}" ]; then
  mkdir -p ~/.ssh
  printf '%s\n' "$DEPLOY_KEY" > ~/.ssh/id_ed25519
  chmod 600 ~/.ssh/id_ed25519
  ssh-keyscan -H "${HOST#*@}" >> ~/.ssh/known_hosts 2>/dev/null || true
fi

echo "→ deploying to $HOST"

$SSH "$HOST" "mkdir -p $DIR/bin"
$SCP docker-compose.yml Caddyfile "$HOST:$DIR/"
$SCP bin/post-consume bin/init-db "$HOST:$DIR/bin/"

# Ensure .env.production exists on remote
if ! $SSH "$HOST" "test -f $DIR/.env.production"; then
  if [ -f .env.production ]; then
    echo "→ syncing .env.production to $HOST"
    $SCP .env.production "$HOST:$DIR/.env.production"
  else
    echo "✗ $DIR/.env.production not found on remote." >&2
    echo "  Run: bin/sync-env $HOST" >&2
    exit 1
  fi
fi

# Fix REDIS_PASSWORD if it contains URL-unsafe chars (breaks redis:// URLs)
$SSH "$HOST" "cd $DIR && if grep -qP 'REDIS_PASSWORD=.*[/@:]' .env.production 2>/dev/null; then
  NEW_PW=\$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c 32)
  sed -i \"s|^REDIS_PASSWORD=.*|REDIS_PASSWORD=\$NEW_PW|\" .env.production
  echo '→ fixed REDIS_PASSWORD (had URL-unsafe chars)'
fi"

# Clean up old Docker images/cache to prevent disk-full issues
$SSH "$HOST" "docker image prune -af --filter 'until=168h' 2>/dev/null; docker builder prune -af --filter 'until=168h' 2>/dev/null" || true

# Registry login (CI provides GHCR_TOKEN)
if [ -n "${GHCR_TOKEN:-}" ] && [ -n "${GHCR_USER:-}" ]; then
  $SSH "$HOST" "echo '$GHCR_TOKEN' | docker login ghcr.io -u '$GHCR_USER' --password-stdin"
fi

if ! $SSH "$HOST" "cd $DIR && docker compose --env-file .env.production pull app && docker compose --env-file .env.production up -d --remove-orphans && docker compose --env-file .env.production up -d --force-recreate --no-deps app caddy"; then
  echo "✗ deploy failed — fetching logs:"
  echo "--- db logs ---"
  $SSH "$HOST" "cd $DIR && docker compose --env-file .env.production logs --tail=30 db" || true
  echo "--- paperless logs ---"
  $SSH "$HOST" "cd $DIR && docker compose --env-file .env.production logs --tail=80 paperless" || true
  echo "--- app logs ---"
  $SSH "$HOST" "cd $DIR && docker compose --env-file .env.production logs --tail=50 app" || true
  exit 1
fi

echo "✓ deployed to $HOST"
