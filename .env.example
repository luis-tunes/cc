# Database
POSTGRES_DB=cc
POSTGRES_USER=cc
POSTGRES_PASSWORD=cc                          # PROD: openssl rand -base64 24

# Paperless-ngx
PAPERLESS_SECRET_KEY=changeme                 # PROD: openssl rand -base64 24
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=admin                # PROD: openssl rand -base64 16
PAPERLESS_TOKEN=                              # PROD: generated after first boot (see README)

# Clerk auth (dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=                             # sk_test_... → .env only (NEVER in frontend)
CLERK_PEM_PUBLIC_KEY=                         # API Keys → Advanced → PEM Public Key
AUTH_DISABLED=1                               # DEV: 1 (skip JWT). PROD: 0
VITE_CLERK_PUBLISHABLE_KEY=                   # pk_test_... → also goes in GitHub Secrets

# Stripe billing (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=                            # sk_test_... → .env only
STRIPE_WEBHOOK_SECRET=                        # whsec_... → Webhooks → your endpoint
STRIPE_PRICE_PRO=                             # price_... → Products → Pro plan price ID
APP_URL=http://localhost:3000                 # PROD: https://yourdomain.pt
CONTACT_EMAIL=info@tim.pt

# Stripe Connect — 50/50 revenue split (optional)
PARTNER_STRIPE_ACCOUNT=                       # acct_... → partner's connected account
REVENUE_SPLIT_PERCENT=50

# Caddy reverse proxy
DOMAIN=:80                                    # HTTP on any IP. PROD: tim.pt (auto-HTTPS via Let's Encrypt)
