# Database
POSTGRES_DB=cc
POSTGRES_USER=cc
POSTGRES_PASSWORD=cc                          # PROD: openssl rand -base64 24

# Paperless-ngx
PAPERLESS_SECRET_KEY=changeme                 # PROD: openssl rand -base64 24
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=admin                # PROD: openssl rand -base64 16
PAPERLESS_TOKEN=                              # PROD: generated after first boot (see README)

# Clerk auth (dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=                             # sk_test_... → .env only (NEVER in frontend)
CLERK_PEM_PUBLIC_KEY=                         # API Keys → Advanced → PEM Public Key
CLERK_WEBHOOK_SECRET=                         # Webhooks → Signing Secret (whsec_...)
AUTH_DISABLED=1                               # DEV: 1 (skip JWT). PROD: 0
VITE_CLERK_PUBLISHABLE_KEY=                   # pk_test_... → also goes in GitHub Secrets

# Stripe billing (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=                            # sk_test_... → .env only
STRIPE_WEBHOOK_SECRET=                        # whsec_... → Webhooks → your endpoint
STRIPE_PRICE_PRO=                             # price_... → Products → Pro plan price ID
APP_URL=https://localhost                       # PROD: https://xtim.ai
CONTACT_EMAIL=info@xtim.ai
MASTER_USER_IDS=                              # Comma-separated Clerk user IDs or emails (e.g. user_abc,me@email.com)

# OpenAI — LLM-powered extraction & classification (optional, regex fallback if empty)
OPENAI_API_KEY=                               # sk-... → platform.openai.com
OPENAI_MODEL=gpt-4.1                         # gpt-4.1 best quality+price. gpt-4.1-mini for budget

# Internal webhook secret (shared between Paperless and app)
WEBHOOK_SECRET=                               # openssl rand -base64 24 — leave blank in dev

# Redis
REDIS_PASSWORD=redis_secret                    # PROD: openssl rand -base64 24

# Caddy reverse proxy
DOMAIN=:80                                     # DEV: HTTP only. PROD: xtim.ai (auto Let's Encrypt)

# Observability
SENTRY_DSN=                                    # https://xxx@sentry.io/yyy (optional)
SENTRY_TRACES_SAMPLE_RATE=0.1                  # 0.0-1.0, fraction of requests traced
LOG_FORMAT=text                                # "json" for structured logging in prod
